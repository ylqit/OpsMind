FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY . /app

EXPOSE 8000

# 先执行一次演示数据初始化，再启动后端服务。
CMD ["sh", "-c", "python scripts/seed_demo_data.py && uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"]


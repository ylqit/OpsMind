# opsMind 环境变量示例
# 复制为 .env 后即可用于本地运行或 docker compose。

# 服务端口
BACKEND_PORT=8000
FRONTEND_PORT=3000
PORT=8000
DEBUG=false

# 数据源
# Compose 最小启动默认使用 logfile。
DATA_SOURCES=logfile
ACCESS_LOG_PATHS=/app/data/raw_logs/access.seed.log

# 演示数据
# true: 启动时自动补齐演示数据，脚本设计为幂等执行。
ENABLE_SEED=true
# true: 每次启动都重置固定演示任务与产物。
SEED_RESET=false

# LLM（可选）
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Docker 数据源（可选）
# Linux/Mac 默认 unix:///var/run/docker.sock
# Windows Docker Desktop 可改为 //./pipe/docker_engine
DOCKER_HOST=unix:///var/run/docker.sock

# Prometheus（可选）
PROMETHEUS_URL=
PROMETHEUS_API_KEY=

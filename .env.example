# opsMind 环境变量示例文件
# 复制此文件为 .env 并填入实际值

# ========== LLM 配置 ==========
# OpenAI API Key（必填）
LLM_API_KEY=your_api_key_here

# LLM 服务商地址（可选，默认为 OpenAI）
LLM_BASE_URL=https://api.openai.com/v1

# 模型名称（可选）
LLM_MODEL=gpt-4o-mini

# ========== Docker 配置 ==========
# Windows Docker Desktop: //./pipe/docker_engine
# Linux/Mac: unix:///var/run/docker.sock
DOCKER_HOST=unix:///var/run/docker.sock

# ========== Kubernetes 配置（可选） ==========
# KUBECONFIG_PATH=~/.kube/config

# ========== 应用配置 ==========
# 服务端口
PORT=8000

# 调试模式（生产环境设为 false）
DEBUG=false

# ========== 数据源配置 ==========
# 启用的数据源列表（docker,logfile,prometheus,kubernetes,elasticsearch）
DATA_SOURCES=docker,logfile
